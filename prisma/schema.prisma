generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Réglages applicatifs (ligne unique "singleton") : code de validation courant.
model AppSetting {
  id             String   @id @default("singleton")
  validationCode String
  updatedAt      DateTime @updatedAt
}

// ---- Auth.js (NextAuth) ----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  verified      Boolean   @default(false) // compte validé via le code (accès au jeu)
  notifyEmail   Boolean   @default(false) // reçoit les rappels par email (désactivé par défaut)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  bets     Bet[]
  votes    Vote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Application ----

// Un jour de "course" : la journée pour laquelle on parie sur l'heure d'arrivée.
model ArrivalDay {
  id           String   @id @default(cuid())
  date         String   @unique // "YYYY-MM-DD" (fuseau du bureau)
  actualMin    Int? // heure d'arrivée réelle en minutes depuis minuit (null si absent ou non saisi)
  actualAbsent Boolean  @default(false) // résultat: le retardataire n'est pas venu
  suspended    Boolean  @default(false) // jour suspendu par l'admin: aucun pari, aucun point
  closed       Boolean  @default(false) // résultat saisi: paris clôturés et scores calculés
  createdAt    DateTime @default(now())

  bets Bet[]
}

// Un pari d'un utilisateur pour un jour donné : une heure OU "absent".
model Bet {
  id              String   @id @default(cuid())
  userId          String
  dayId           String
  predictedMin    Int? // heure pariée en minutes depuis minuit (null si pari "absent")
  predictedAbsent Boolean  @default(false) // l'utilisateur parie qu'il ne viendra pas
  points          Int? // score attribué (null tant que le jour n'est pas clôturé)
  createdAt       DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  day  ArrivalDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

// ---- Défis : pari "vote sur une liste de personnes" ----

// Un défi : une question (ex. "Prochaine personne à quitter la boîte ?") + des candidats.
model PickGame {
  id                String    @id @default(cuid())
  title             String
  description       String?
  status            String    @default("open") // "open" | "closed"
  showVoters        Boolean   @default(true) // afficher aux participants qui a voté pour qui
  winnerCandidateId String? // candidat désigné gagnant à la clôture
  createdAt         DateTime  @default(now())
  closedAt          DateTime?

  candidates Candidate[]
  votes      Vote[]
}

// Une personne proposée au vote dans un défi.
model Candidate {
  id     String @id @default(cuid())
  gameId String
  name   String

  game  PickGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  votes Vote[]
}

// Le vote d'un utilisateur pour un candidat dans un défi.
model Vote {
  id          String   @id @default(cuid())
  gameId      String
  userId      String
  candidateId String
  points      Int? // attribué à la clôture (100 si bon candidat, 0 sinon)
  createdAt   DateTime @default(now())

  game      PickGame  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}
